{
  "name": "bugfind-15",
  "version": "0.1.0",
  "description": "BugFind-15 is a visual benchmark dashboard for evaluating LLM bug-finding performance.",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "benchmark:cli": "node scripts/run-benchmark-cli.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify:sandbox:build": "node scripts/verify-sandbox.mjs build",
    "verify:canonical": "node scripts/verify-sandbox.mjs run",
    "verify:canonical:rebuild": "node scripts/verify-sandbox.mjs rebuild",
    "verify:sandbox:serve": "node scripts/verify-sandbox.mjs serve",
    "verify:sandbox:stop": "node scripts/verify-sandbox.mjs stop"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest"
  }
}

{
  "schemaVersion": 1,
  "protocolVersion": 1,
  "id": "bugfind-15",
  "name": "BugFind-15",
  "version": "0.1.0",
  "description": "Execution-backed debugging benchmark with verifier-backed scoring across 15 fixed scenarios.",
  "entry": "./dist/benchlocal/index.js",
  "theme": {
    "accent": "#1f5f78"
  },
  "capabilities": {
    "tools": false,
    "multiTurn": true,
    "streamingProgress": true,
    "sidecars": true,
    "standaloneWebApp": true
  },
  "sidecars": [
    {
      "id": "verifier",
      "kind": "docker-http",
      "required": true,
      "defaultPort": 4010,
      "healthcheckPath": "/health"
    }
  ]
}

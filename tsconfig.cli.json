{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist-cli",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "es2022",
      "dom"
    ],
    "jsx": "react-jsx",
    "incremental": false,
    "tsBuildInfoFile": "./tsconfig.cli.tsbuildinfo"
  },
  "include": [
    "cli/**/*.ts",
    "lib/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
